<?xml version="1.0" encoding="UTF-8"?>
<!--
  examples/runtime/open_switch.conf.xml — config for the demo container.
  This is a copy of deploy/freeswitch/conf/autoload_configs/open_switch.conf.xml
  with the gRPC listen address narrowed to 0.0.0.0:50061 (so docker -p
  50061:50061 works) and otherwise compiled-in defaults.
-->
<configuration name="open_switch.conf" description="mod_open_switch settings">
  <settings>
    <!-- Bind on all interfaces so docker -p 50061:50061 forwards in. -->
    <param name="grpc_listen_address" value="0.0.0.0:50061"/>

    <param name="grpc_max_concurrent_streams" value="256"/>
    <param name="grpc_drain_deadline_seconds" value="2"/>

    <!-- W4 will land TLS; for demo we run insecure on the host loopback. -->
    <param name="grpc_tls_cert_path" value=""/>
    <param name="grpc_tls_key_path"  value=""/>
    <param name="grpc_tls_ca_path"   value=""/>

    <param name="event_ring_capacity_tier1" value="16384"/>
    <param name="event_ring_capacity_tier2" value="8192"/>
    <param name="event_ring_capacity_tier3" value="4096"/>
    <param name="subscriber_send_queue_capacity" value="4096"/>
    <param name="max_subscribers" value="16"/>

    <param name="idempotency_ttl_seconds"                  value="300"/>
    <param name="idempotency_cache_capacity"               value="1500"/>
    <param name="idempotency_in_flight_max_wait_seconds"   value="30"/>

    <param name="drain_timeout_seconds"        value="30"/>
    <param name="event_drain_timeout_seconds"  value="5"/>

    <param name="osw_panic_on_unhandled"        value="false"/>
    <param name="osw_install_signal_handlers"   value="false"/>

    <param name="log_level"                value="info"/>
    <param name="pii_redaction_patterns"   value=""/>
    <param name="tenant_allowed_contexts"  value=""/>

    <!-- W6 Track C — TTS playout jitter buffer (compiled-in defaults) -->
    <param name="tts_jitter_buffer_ms"      value="1000"/>
    <param name="tts_preroll_ms"            value="200"/>
    <param name="tts_high_water_ms"         value="3000"/>
    <param name="tts_max_jitter_buffer_ms"  value="5000"/>
    <param name="tts_underrun_policy"       value="silence"/>

    <!-- W7 Track B — recording relay defaults -->
    <param name="recording_send_ring_ms"       value="500"/>
    <param name="stereo_desync_warn_ms"        value="5"/>
    <param name="stereo_desync_timeout_ms"     value="25"/>
    <param name="recording_default_rate_hz"    value="8000"/>
    <param name="warn_record_before_inject"    value="true"/>

    <!-- W6.6 — module-owned write-side driver for parked WRITE_REPLACE channels -->
    <param name="silence_driver_enabled"    value="true"/>
    <param name="max_silence_drivers"       value="200"/>

    <!-- W7 Track D — StartBot facade defaults -->
    <param name="bot_max_targets"           value="2"/>
    <param name="bot_target_queue_ms"       value="500"/>
    <param name="bot_drain_timeout_ms"      value="2000"/>
    <param name="max_bots_per_channel"      value="1"/>

    <!-- W7 Track A — eavesdrop policy on bot-marked calls -->
    <param name="eavesdrop_policy"          value="deny"/>
    <param name="tenant_eavesdrop_policies" value=""/>
  </settings>
</configuration>
