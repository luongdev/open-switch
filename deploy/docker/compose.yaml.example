# Example compose: FreeSWITCH + mod_open_switch.
#
# Phase-1-fix-sprint note: this compose no longer ships Redis. Module
# event delivery is gRPC-only; operator's event consumer (running
# wherever the operator chooses) does its own durability. See
# openspec/changes/core-module-v1/designs/transport-adr.md.
#
# Adjust IPs / ACLs / passwords / TLS material before production use.

services:
  freeswitch:
    image: open-switch/freeswitch:0.1.0
    network_mode: host    # required for SIP/RTP dynamic ports
    shm_size: 256m
    environment:
      FS_PROFILE: nat
      FS_PRIVATE_IP: 10.0.0.5
      FS_PUBLIC_IP: 203.0.113.50
      FS_DOMAIN: sip.example.com
      FS_MAX_SESSIONS: 5000
      FS_SESSIONS_PER_SECOND: 100
      FS_LOG_LEVEL: warning
      OPEN_SWITCH_GRPC_PORT: 50061
    cap_add:
      - SYS_NICE
      - SYS_RESOURCE
      - NET_RAW
    ulimits:
      nofile: { soft: 999999, hard: 999999 }
      memlock: { soft: -1, hard: -1 }
    volumes:
      - ./conf/freeswitch:/etc/freeswitch
      - ./conf/modules.conf.xml:/etc/freeswitch/autoload_configs/modules.conf.xml:ro
      - ./conf/open_switch.conf.xml:/etc/freeswitch/autoload_configs/open_switch.conf.xml:ro
      - ./logs:/var/log/freeswitch
      - ./recordings:/opt/freeswitch/recordings
      # Optionally mount TLS material for gRPC mTLS:
      # - ./tls:/etc/freeswitch/tls:ro
    restart: unless-stopped

  # Operator's event subscriber goes here (or runs on a different host
  # entirely). Examples for reference:
  #
  # event-consumer-primary:
  #   image: my-org/osw-event-consumer:latest
  #   environment:
  #     OSW_GRPC_TARGET: freeswitch:50061
  #     OSW_TLS_CA: /tls/ca.pem
  #     KAFKA_BOOTSTRAP: kafka:9092
  #     SUBSCRIBER_ROLE: primary
  #   depends_on:
  #     freeswitch:
  #       condition: service_healthy
  #
  # event-consumer-standby:
  #   image: my-org/osw-event-consumer:latest
  #   environment:
  #     OSW_GRPC_TARGET: freeswitch:50061
  #     SUBSCRIBER_ROLE: standby
  #     # ... same as primary; both write to durable store, dedup by event_id
